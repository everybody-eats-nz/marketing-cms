{
  "name": "marketing-cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "extract:webflow": "tsx scripts/extract-webflow.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.50.0",
    "@payloadcms/email-resend": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.50.0",
    "@payloadcms/payload-cloud": "^3.50.0",
    "@payloadcms/richtext-lexical": "^3.50.0",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/ui": "^3.50.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "next": "15.4.4",
    "payload": "^3.85.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.34.2",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.4",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
