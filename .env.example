# Database
DATABASE_URI=postgres://payload:payload@localhost:5433/everybodyeats

# Payload
PAYLOAD_SECRET=replace-me-with-long-random-string

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Volunteer portal — base URL of the volunteer portal app. Used to pull live
# impact stats (people served, volunteer hours, food saved) for the Stats block
# via <portal>/api/public/impact-stats. Leave empty to fall back to the fixed
# values configured in the CMS.
#   e.g. VOLUNTEER_PORTAL_URL=https://volunteers.everybodyeats.nz
VOLUNTEER_PORTAL_URL=

# Stripe — powers the embedded pay-what-you-feel flow (/dine-with-us/pay).
# The card form is Stripe's Payment Element rendered on our own page; a
# PaymentIntent is created server-side. Without these keys the pay page shows a
# "see our team at the counter" fallback.
#   STRIPE_SECRET_KEY                  — server-side (sk_…). Creates PaymentIntents.
#   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY — browser (pk_…). Mounts the Payment Element.
#   STRIPE_WEBHOOK_SECRET              — signing secret (whsec_…) for the webhook
#                                        at /api/donate/webhook that records donations.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Anthropic — powers AI sentiment classification of diner feedback
# (src/lib/sentiment.ts). Positive + consented feedback auto-publishes to the
# restaurant pages. Without a key, feedback is still saved but left as "pending"
# for manual review. SENTIMENT_MODEL defaults to claude-opus-4-8; set it to a
# cheaper model (e.g. claude-haiku-4-5) for high volume.
ANTHROPIC_API_KEY=
SENTIMENT_MODEL=

# Webflow extraction (only needed for `pnpm extract:webflow`)
WEBFLOW_API_TOKEN=
WEBFLOW_SITE_ID=

# Media object storage (S3-compatible). Leave S3_BUCKET empty to use local-disk
# storage (fine for local dev). Set all of these in prod (Coolify) and also in
# your local shell when seeding media into prod.
#
# Cloudflare R2 example:
#   S3_BUCKET=everybody-eats-media
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_ACCESS_KEY_ID=<r2-access-key-id>
#   S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
#   S3_FORCE_PATH_STYLE=true
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
